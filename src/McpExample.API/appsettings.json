{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "McpExample",
    "Audience": "McpExampleClients",
    "ExpiryMinutes": "60"
  },
  "McpSettings": {
    "ApiKey": "CHANGE_ME_TO_A_SECURE_MCP_API_KEY"
  }
}
